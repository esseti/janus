# Docker image (override only if you build your own fork; defaults to the
# public image in docker-compose.yml).
# JANUS_IMAGE=ghcr.io/esseti/janus:latest

# Paths to Google OAuth files (defaults to current directory).
# Download credentials.json from Google Cloud Console > APIs & Services > Credentials.
# token.json is generated automatically after running the auth flow.
# CREDENTIALS_FILE=./credentials.json
# TOKEN_FILE=./token.json

# LLM backend: "gemini" or "ollama"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash-lite
LLM_TEMPERATURE=0.3

# Gemini API key (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama base URL (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Google Chat incoming webhook for notifications
GOOGLE_CHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=KEY&token=TOKEN

# Gmail label that Janus monitors
TARGET_LABEL=janus

# Your Gmail address and display name
USER_EMAIL=you@example.com
USER_NAME=Your Name

# Mailgun — used for the email digest
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
