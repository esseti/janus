# --- Janus - Git Ignore ---

# Secrets (never commit these)
.env
credentials.json
token.json

# Runtime state & logs
last_run.txt
*.log
processed_not_notified.json
processed_notified.json
feedback.json
mailing_list.json

# User-specific config (lives in DATA_DIR on server)
excluded_senders.txt
evaluation_rules.txt

# Python
.venv/
__pycache__/
*.py[cod]
*$py.class

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local tooling state
.poetrysync
.pull
.uvsync
.deploy_config
logrotate.conf
logrotate.state

# Claude Code internal
.claude/

exports/*